<ui:FluentWindow x:Class="SlipSnap.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:models="clr-namespace:SlipSnap.Models"
        Title="SlipSnap Settings"
        Width="450" Height="550"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        ExtendsContentIntoTitleBar="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar Title="SlipSnap Settings" Grid.Row="0" />

        <ScrollViewer Grid.Row="1" Margin="16,0,16,16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- Theme -->
                <TextBlock Text="Theme" FontWeight="SemiBold" FontSize="16" Margin="0,8,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <RadioButton Content="Auto" GroupName="Theme"
                                 IsChecked="{Binding Theme, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:ThemeMode.Auto}}" Margin="0,0,12,0" />
                    <RadioButton Content="Light" GroupName="Theme"
                                 IsChecked="{Binding Theme, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:ThemeMode.Light}}" Margin="0,0,12,0" />
                    <RadioButton Content="Dark" GroupName="Theme"
                                 IsChecked="{Binding Theme, Converter={StaticResource EnumBoolConverter}, ConverterParameter={x:Static models:ThemeMode.Dark}}" />
                </StackPanel>

                <!-- Transparency -->
                <TextBlock Text="Transparency" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                    <Slider Minimum="10" Maximum="100" Width="280"
                            Value="{Binding OpacityPercent, Mode=TwoWay}" TickFrequency="10" IsSnapToTickEnabled="True" />
                    <TextBlock Margin="8,0,0,0" VerticalAlignment="Center">
                        <Run Text="{Binding OpacityPercent, Mode=OneWay}" /><Run Text="%" />
                    </TextBlock>
                </StackPanel>

                <!-- Toolbar Edges -->
                <TextBlock Text="Toolbar Positions" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />

                <CheckBox Content="Left edge" IsChecked="{Binding IsLeftEnabled}" Margin="0,0,0,2" />
                <StackPanel Margin="24,0,0,4" Orientation="Horizontal" Visibility="{Binding IsLeftEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <CheckBox Content="Start" IsChecked="{Binding LeftButtons.HasStartMenu}" Margin="0,0,8,0" />
                    <CheckBox Content="Task View" IsChecked="{Binding LeftButtons.HasTaskView}" Margin="0,0,8,0" />
                    <CheckBox Content="Prev" IsChecked="{Binding LeftButtons.HasPrevDesktop}" Margin="0,0,8,0" />
                    <CheckBox Content="Next" IsChecked="{Binding LeftButtons.HasNextDesktop}" />
                </StackPanel>

                <CheckBox Content="Right edge" IsChecked="{Binding IsRightEnabled}" Margin="0,0,0,2" />
                <StackPanel Margin="24,0,0,4" Orientation="Horizontal" Visibility="{Binding IsRightEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <CheckBox Content="Start" IsChecked="{Binding RightButtons.HasStartMenu}" Margin="0,0,8,0" />
                    <CheckBox Content="Task View" IsChecked="{Binding RightButtons.HasTaskView}" Margin="0,0,8,0" />
                    <CheckBox Content="Prev" IsChecked="{Binding RightButtons.HasPrevDesktop}" Margin="0,0,8,0" />
                    <CheckBox Content="Next" IsChecked="{Binding RightButtons.HasNextDesktop}" />
                </StackPanel>

                <CheckBox Content="Top edge" IsChecked="{Binding IsTopEnabled}" Margin="0,0,0,2" />
                <StackPanel Margin="24,0,0,4" Orientation="Horizontal" Visibility="{Binding IsTopEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <CheckBox Content="Start" IsChecked="{Binding TopButtons.HasStartMenu}" Margin="0,0,8,0" />
                    <CheckBox Content="Task View" IsChecked="{Binding TopButtons.HasTaskView}" Margin="0,0,8,0" />
                    <CheckBox Content="Prev" IsChecked="{Binding TopButtons.HasPrevDesktop}" Margin="0,0,8,0" />
                    <CheckBox Content="Next" IsChecked="{Binding TopButtons.HasNextDesktop}" />
                </StackPanel>

                <CheckBox Content="Bottom edge" IsChecked="{Binding IsBottomEnabled}" Margin="0,0,0,2" />
                <StackPanel Margin="24,0,0,16" Orientation="Horizontal" Visibility="{Binding IsBottomEnabled, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <CheckBox Content="Start" IsChecked="{Binding BottomButtons.HasStartMenu}" Margin="0,0,8,0" />
                    <CheckBox Content="Task View" IsChecked="{Binding BottomButtons.HasTaskView}" Margin="0,0,8,0" />
                    <CheckBox Content="Prev" IsChecked="{Binding BottomButtons.HasPrevDesktop}" Margin="0,0,8,0" />
                    <CheckBox Content="Next" IsChecked="{Binding BottomButtons.HasNextDesktop}" />
                </StackPanel>

                <!-- Behavior -->
                <TextBlock Text="Behavior" FontWeight="SemiBold" FontSize="16" Margin="0,0,0,8" />
                <CheckBox Content="Only show when a fullscreen window is present"
                          IsChecked="{Binding FullscreenOnly}" Margin="0,0,0,4" />
                <CheckBox Content="Hide toolbars in RDP session"
                          IsChecked="{Binding HideInRdpSession}" Margin="0,0,0,16" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</ui:FluentWindow>
